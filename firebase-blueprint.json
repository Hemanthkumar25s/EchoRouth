{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the EchoRouth app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "generationCount": { "type": "number" },
        "isPremium": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "createdAt"]
    },
    "Podcast": {
      "title": "Podcast",
      "description": "A generated podcast script.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "script": { "type": "string" },
        "tone": { "type": "string" },
        "length": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "script", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/podcasts/{podcastId}": {
      "schema": { "$ref": "#/entities/Podcast" },
      "description": "Stores generated podcasts for users."
    }
  }
}
