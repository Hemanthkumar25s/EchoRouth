# USER_GEMINI_KEY: Required for Gemini AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
USER_GEMINI_KEY="MY_USER_GEMINI_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://echorouth-152970275957.us-west1.run.app"

# RAZORPAY_KEY_ID: Required for Razorpay payments (UPI, Cards, etc.)
RAZORPAY_KEY_ID=

# RAZORPAY_KEY_SECRET: Required for Razorpay payments
RAZORPAY_KEY_SECRET=

# RAZORPAY_PLAN_ID: Optional. If provided, the app will use Razorpay Subscriptions (Auto-Pay) instead of one-time orders.
RAZORPAY_PLAN_ID=

# COUPON_DATA: JSON string of valid coupons and their discount percentages. e.g. {"PRO50": 50, "FREE": 100}
COUPON_DATA='{}'
